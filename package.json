{
  "name": "tradie-app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "cp .env.local .env && expo start --port 8082",
    "android": "cp .env.local .env && expo start --android --port 8082",
    "ios": "cp .env.local .env && expo start --ios --port 8082",
    "web": "cp .env.local .env && expo start --web --port 8082",
    "emulators": "firebase emulators:start --only functions,firestore,storage",
    "start:prod": "expo start",
    "android:prod": "expo start --android",
    "ios:prod": "expo start --ios",
    "web:prod": "expo start --web",
    "build:web": "expo export -p web",
    "deploy": "npm run build:web && firebase deploy --only hosting,functions",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:indexes": "firebase deploy --only firestore:indexes",
    "deploy:hosting": "npm run build:web && firebase deploy --only hosting",
    "deploy:rules": "firebase deploy --only firestore:rules,storage",
    "deploy:all": "npm run build:web && firebase deploy",
    "populate-firestore": "node scripts/populateFirestore.js",
    "seed": "cp .env.local .env && node bin/data/seed.js",
    "build:android": "eas build -p android --profile preview --local",
    "build:ios": "eas build -p ios --profile preview --local",
    "run:android": "npx expo run:android",
    "run:ios": "npx expo run:ios"
  },
  "dependencies": {
    "@expo/config-plugins": "^56.0.8",
    "@firebase/app": "^0.14.1",
    "@firebase/auth": "^1.11.0",
    "@firebase/firestore": "^4.9.0",
    "@firebase/functions": "^0.13.0",
    "@firebase/storage": "^0.14.0",
    "@gluestack-ui/config": "^1.1.20",
    "@gluestack-ui/provider": "^0.1.19",
    "@gluestack-ui/themed": "^1.1.73",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/app-check": "^24.0.0",
    "@react-native-firebase/auth": "^24.0.0",
    "@react-native-firebase/crashlytics": "^24.0.0",
    "@react-native-firebase/firestore": "^24.0.0",
    "@react-native-firebase/functions": "^24.0.0",
    "@react-native-firebase/messaging": "^24.0.0",
    "@react-native-firebase/storage": "^24.0.0",
    "@react-navigation/bottom-tabs": "^7.4.6",
    "@react-navigation/native": "^7.1.17",
    "@react-navigation/native-stack": "^7.3.25",
    "@react-navigation/stack": "^7.4.7",
    "babel-plugin-module-resolver": "^5.0.3",
    "expo": "^56.0.8",
    "expo-av": "^15.1.7",
    "expo-build-properties": "^56.0.16",
    "expo-camera": "~56.0.7",
    "expo-constants": "~56.0.16",
    "expo-document-picker": "~56.0.4",
    "expo-image-picker": "~56.0.15",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.13",
    "expo-media-library": "~56.0.6",
    "expo-notifications": "~56.0.15",
    "expo-splash-screen": "^56.0.10",
    "expo-status-bar": "~56.0.4",
    "lucide-react-native": "^0.541.0",
    "nativewind": "^4.1.23",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-error-boundary": "^6.1.2",
    "react-hook-form": "^7.62.0",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "^4.4.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-ui-datepicker": "^3.1.2",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "^0.9.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@types/react": "~19.2.14",
    "@types/react-native": "^0.72.8",
    "dotenv": "^17.2.2",
    "firebase": "^12.2.1",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.3"
  },
  "private": true
}
