# Cloud Functions runtime environment variables.
# Copy to `.env` (and/or `.env.<projectId>`) in this functions directory.
# Firebase deploys these with the functions. Never commit real secrets.

# --- Payments (Stripe) ---
# Master switch for live payments on the server. When 'true', wallet credits
# REQUIRE a verified Stripe charge (PaymentIntent or Checkout Session). When
# 'false'/unset, rechargeWallet issues a direct dev credit.
PAYMENTS_LIVE=false

# Stripe secret key (sk_live_... or sk_test_...). Required when PAYMENTS_LIVE=true.
STRIPE_SECRET_KEY=

# Stripe webhook signing secret (whsec_...). Required for the stripeWebhook
# backstop that credits wallets directly from Stripe events. Get it from the
# Stripe Dashboard → Developers → Webhooks for the endpoint:
#   https://<region>-<projectId>.cloudfunctions.net/stripeWebhook
# Subscribe to: checkout.session.completed, payment_intent.succeeded
STRIPE_WEBHOOK_SECRET=
